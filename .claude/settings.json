{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "claude -p 'auto-memory:sync' --allowedTools 'Read,Edit,Write,Bash,TodoWrite' 2>/dev/null",
            "async": true,
            "statusMessage": "Syncing auto-memory..."
          }
        ]
      }
    ]
  }
}
