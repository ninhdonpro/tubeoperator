---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPosts, getCategories } from '../../lib/wordpress';

const { posts } = await getPosts(100);
const categories = await getCategories();

function stripHtml(html: string): string {
  return html.replace(/<[^>]*>/g, '').replace(/\\n/g, ' ').trim();
}

function getCategoryName(post: any, cats: any[]): string {
  const catId = post.categories?.[0];
  const cat = cats.find((c: any) => c.id === catId);
  return cat?.name || 'Uncategorized';
}

// Category color mapping from design
const catColors: Record<string, string> = {
  'Algorithm':'#E62117','Thumbnails':'#4F46E5','Editing':'#F2683C',
  'Scripting':'#0E9488','Growth':'#7C3AED','Monetization':'#0F0F0F',
};
function getCatColor(catName: string): string {
  return catColors[catName] || '#E62117';
}

function getFeaturedImage(post: any): string | null {
  const media = post._embedded?.['wp:featuredmedia']?.[0];
  return media?.source_url || null;
}
---

<BaseLayout title="Blog" activePage="blog">
<section class="blog">
  <nav class="crumb"><a href="/">Home</a><span class="sep">/</span><span class="cur">Blog</span></nav>

  <div class="blog-head">
    <h1>Playbooks To Grow Your Channel</h1>
    <p>Data-backed strategies on the algorithm, thumbnails, editing and monetization — written by operators who've done it.</p>
  </div>

  <!-- FEATURED (first post) -->
  {posts.length > 0 && (() => {
    const fp = posts[0];
    const fpCat = getCategoryName(fp, categories);
    const fpImg = getFeaturedImage(fp);
    return (
      <a href={`/${fp.slug}`} class="featured">
        <div class="fc" style={fpImg ? `background-image:url(${fpImg})` : `background:${getCatColor(fpCat)}`}>
          <span class="badge badge-dark fbadge">Editor's pick</span>
        </div>
        <div class="ftxt">
          <h2 set:html={fp.title.rendered} />
        </div>
      </a>
    );
  })()}

  <!-- NEWSLETTER BAND -->
  <div class="nl-band" style="margin-top:0;margin-bottom:var(--sp-7)">
    <div class="nl-txt">
      <span class="badge badge-red" style="margin-bottom:14px"><svg viewBox="0 0 24 24"><path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4-8 5-8-5V6l8 5 8-5z"/></svg>Weekly Newsletter</span>
      <h3>The Operator's Brief</h3>
      <p>One sharp, data-backed lesson on growing your channel — every Thursday. Join <b style="color:#fff;font-weight:700">5,247+ creators</b>.</p>
    </div>
    <form onsubmit="return false">
      <input type="email" placeholder="you@channel.com" aria-label="Email address">
      <button class="btn btn-primary" type="submit">Subscribe</button>
    </form>
  </div>

  <!-- GRID -->
  <div class="card-grid">
    {posts.map((post: any) => {
      const pCat = getCategoryName(post, categories);
      const pImg = getFeaturedImage(post);
      return (
        <a href={`/${post.slug}`} class="art-card">
          <div class="art-cover" style={pImg ? `background-image:url(${pImg})` : `background:${getCatColor(pCat)}`}>
          </div>
          <div class="art-body">
            <h3 class="art-title" set:html={post.title.rendered} />
          </div>
        </a>
      );
    })}
  </div>
</section>
</BaseLayout>

<style>
/* ===== Blog shell ===== */
.blog{max-width:1400px;margin:0 auto;padding:var(--sp-7) 48px var(--sp-8)}
.crumb{font-size:15px;color:var(--ink-500);margin-bottom:var(--sp-5)}
.crumb a:hover{color:var(--red-600)}
.crumb .sep{margin:0 8px;color:var(--ink-300)}
.crumb .cur{color:var(--ink-900);font-weight:600}
.blog-head{max-width:720px;margin-bottom:var(--sp-7)}
.blog-head h1{font-family:var(--font-display);font-weight:800;font-size:48px;line-height:1.1;letter-spacing:-.03em;text-transform:capitalize}
.blog-head p{font-size:20px;color:var(--ink-600);margin-top:var(--sp-3);line-height:1.6}

/* featured */
.featured{display:grid;grid-template-columns:16fr 9fr;background:var(--bg-surface);border:1px solid var(--ink-200);
  border-radius:var(--r-xl);overflow:hidden;box-shadow:var(--sh-2);margin-bottom:var(--sp-7);cursor:pointer;transition:box-shadow var(--dur) var(--ease)}
.featured:hover{box-shadow:var(--sh-3)}
.featured .fc{aspect-ratio:16/9;display:flex;align-items:flex-end;padding:var(--sp-6);position:relative;
  background-size:cover;background-position:center;background-repeat:no-repeat}
.featured .fc .fbadge{position:absolute;top:var(--sp-5);left:var(--sp-6)}
.featured .ftxt{padding:var(--sp-7) var(--sp-6);display:flex;flex-direction:column;justify-content:center}
.featured .ftxt h2{font-family:var(--font-display);font-weight:800;font-size:30px;line-height:1.18;letter-spacing:-.02em;margin:0}

/* newsletter band */
.nl-band{background:var(--bg-dark);border-radius:var(--r-xl);padding:var(--sp-7);margin-top:var(--sp-8);
  display:flex;align-items:center;justify-content:space-between;gap:var(--sp-6);flex-wrap:wrap}
.nl-band .nl-txt{flex:1;min-width:280px;max-width:48ch}
.nl-band h3{font-family:var(--font-display);font-weight:800;font-size:28px;color:#fff;letter-spacing:-.02em;text-transform:capitalize}
.nl-band p{font-size:16px;color:rgba(255,255,255,.65);margin-top:8px;line-height:1.55}
.nl-band form{display:flex;gap:12px;flex:1;min-width:300px;max-width:440px}
.nl-band input{flex:1;font-family:var(--font-body);font-size:16px;line-height:1;padding:16px 18px;border:1px solid rgba(255,255,255,.18);border-radius:var(--r-sm);background:rgba(255,255,255,.08);color:#fff}
.nl-band input::placeholder{color:rgba(255,255,255,.5)}
.nl-band input:focus{outline:2px solid var(--red-500)}

/* card grid */
.card-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--sp-5)}
.art-card{background:var(--bg-surface);border:1px solid var(--ink-200);border-radius:var(--r-lg);overflow:hidden;
  box-shadow:var(--sh-1);transition:box-shadow var(--dur) var(--ease),transform var(--dur) var(--ease);cursor:pointer;display:flex;flex-direction:column}
.art-card:hover{box-shadow:var(--sh-3);transform:translateY(-3px)}
.art-cover{aspect-ratio:16/9;background-size:cover;background-position:center;background-repeat:no-repeat}
.art-body{padding:var(--sp-5)}
.art-title{font-family:var(--font-display);font-weight:700;font-size:21px;line-height:1.3;margin:0;letter-spacing:-.01em}

@media(max-width:980px){
  .blog{padding:var(--sp-6) 24px var(--sp-7)}
  .blog-head h1{font-size:38px}
  .featured{grid-template-columns:1fr}
  .card-grid{grid-template-columns:1fr 1fr}
}
@media(max-width:620px){
  .blog-head h1{font-size:32px}
  .card-grid{grid-template-columns:1fr}
  .nl-band{padding:var(--sp-6)}
  .nl-band form{min-width:100%;max-width:none}
  .nl-band h3{font-size:24px}
}
</style>
