---
import BaseLayout from '../layouts/BaseLayout.astro';
const embedLayout = "{'id':'INLINE'}";
---

<BaseLayout title="Build a 7-figure YouTube channel with AI" activePage="home">
<!-- ===== HERO NEWSLETTER ===== -->
<section class="hero">
  <span class="badge badge-soft eyebrow">Free weekly newsletter</span>
  <h1>The Fastest Way To Build a <span class="hl">7-Figure</span> YouTube Channel</h1>
  <p class="sub">Get the exact AI tools, strategies and systems that helped hundreds of operators grow <b>7-figure YouTube channels</b> — in one free email every week.</p>

  <!-- nl-form hidden, replaced by iframe below -->
  <!-- <form class="nl-form" onsubmit="window.location.href='/welcome';return false;">
    <input type="email" placeholder="Your email address" aria-label="Email address">
    <button class="btn btn-primary" type="submit">Show me how <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
  </form> -->

  <div class="embed-form">
    <iframe
      src="https://api.automator.vn/widget/form/M4dgGmoyayFfbdfldxdi"
      style="width:100%;height:100%;border:none;border-radius:0px"
      id="inline-M4dgGmoyayFfbdfldxdi"
      data-layout={embedLayout}
      data-trigger-type="alwaysShow"
      data-trigger-value=""
      data-activation-type="alwaysActivated"
      data-activation-value=""
      data-deactivation-type="neverDeactivate"
      data-deactivation-value=""
      data-form-name="YouTube Newsletter Form"
      data-height="400"
      data-layout-iframe-id="inline-M4dgGmoyayFfbdfldxdi"
      data-form-id="M4dgGmoyayFfbdfldxdi"
      title="YouTube Newsletter Form"
    ></iframe>
  </div>
  <script is:inline src="https://api.automator.vn/js/form_embed.js"></script>

  <div class="proof">
    <div class="avatars">
      <span style="background:#E62117">JM</span>
      <span style="background:#4F46E5">AK</span>
      <span style="background:#0E9488">LT</span>
      <span style="background:#E8920C">SD</span>
      <span style="background:#7C3AED">RK</span>
    </div>
    <div class="trust-line">
      <span class="stars"><svg viewBox="0 0 24 24"><path d="m12 17.3 6.2 3.7-1.6-7L22 9.2l-7.2-.6L12 2 9.2 8.6 2 9.2l5.4 4.8-1.6 7z"/></svg><svg viewBox="0 0 24 24"><path d="m12 17.3 6.2 3.7-1.6-7L22 9.2l-7.2-.6L12 2 9.2 8.6 2 9.2l5.4 4.8-1.6 7z"/></svg><svg viewBox="0 0 24 24"><path d="m12 17.3 6.2 3.7-1.6-7L22 9.2l-7.2-.6L12 2 9.2 8.6 2 9.2l5.4 4.8-1.6 7z"/></svg><svg viewBox="0 0 24 24"><path d="m12 17.3 6.2 3.7-1.6-7L22 9.2l-7.2-.6L12 2 9.2 8.6 2 9.2l5.4 4.8-1.6 7z"/></svg><svg viewBox="0 0 24 24"><path d="m12 17.3 6.2 3.7-1.6-7L22 9.2l-7.2-.6L12 2 9.2 8.6 2 9.2l5.4 4.8-1.6 7z"/></svg></span>
      Trusted by <b>5,247+</b> creators &amp; operators across <b>10+ countries</b>
    </div>
  </div>

  <div class="gift">
    <span class="gi"><svg viewBox="0 0 24 24"><path d="M20 7h-2.2a3 3 0 00-4.3-3.9L12 4.2l-1.5-1.1A3 3 0 006.2 7H4a1 1 0 00-1 1v3a1 1 0 001 1v6a2 2 0 002 2h12a2 2 0 002-2v-6a1 1 0 001-1V8a1 1 0 00-1-1zm-5-2a1 1 0 011 1 1 1 0 01-1 1h-1V6a1 1 0 011-1zM9 5a1 1 0 011 1v1H9a1 1 0 010-2zm2 14H6v-6h5zm0-8H5V9h6zm7 8h-5v-6h5zm1-8h-6V9h6z"/></svg></span>
    <p><b>Free when you join:</b> The AI YouTube Toolkit (18 tools + $48,000 in discounts) — plus instant access to the Tube Operator Community.</p>
  </div>
</section>

<!-- ===== FEATURED IN ===== -->
<section class="featured-in">
  <div class="lbl">As featured in</div>
  <div class="press">
    <span class="pl">TechCrunch</span>
    <span class="pl">Forbes</span>
    <span class="pl">The Verge</span>
    <span class="pl">Wired</span>
    <span class="pl">Entrepreneur</span>
  </div>
</section>
</BaseLayout>

<style>
/* ===== Hero ===== */
.hero{max-width:980px;margin:0 auto;padding:var(--sp-9) 48px var(--sp-6);text-align:center}
.hero .eyebrow{margin-bottom:var(--sp-5)}
.hero h1{font-family:var(--font-display);font-weight:800;font-size:60px;line-height:1.22;letter-spacing:-.038em;max-width:880px;margin:0 auto;text-transform:capitalize}
.hero h1 .hl{color:var(--red-500);position:relative;white-space:nowrap}
.hero h1 .hl::after{content:"";position:absolute;left:0;right:0;bottom:.02em;height:.09em;background:var(--red-300);border-radius:4px}
.hero .sub{font-size:21px;color:var(--ink-600);max-width:54ch;margin:var(--sp-5) auto 0;line-height:1.6}
.hero .sub b{color:var(--ink-900);font-weight:700}

.embed-form{max-width:620px;height:155px;overflow:hidden;margin:var(--sp-4) auto 0}
.nl-form{display:flex;gap:12px;max-width:560px;margin:var(--sp-7) auto 0}
.nl-form input{flex:1;font-family:var(--font-body);font-size:18px;line-height:1;padding:19px 22px;border:1.5px solid var(--ink-200);
  border-radius:var(--r-sm);background:var(--bg-surface);transition:border-color .12s var(--ease),box-shadow .12s var(--ease)}
.nl-form input::placeholder{color:var(--ink-400)}
.nl-form input:focus{outline:none;border-color:var(--red-500);box-shadow:0 0 0 3px var(--red-100)}

.proof{margin-top:var(--sp-6);display:flex;flex-direction:column;align-items:center;gap:var(--sp-3)}
.avatars{display:flex}
.avatars span{width:38px;height:38px;border-radius:50%;border:2.5px solid var(--bg-page);margin-left:-10px;display:grid;place-items:center;font-size:13px;font-weight:700;color:#fff}
.avatars span:first-child{margin-left:0}
.trust-line{font-size:16px;color:var(--ink-600)}
.trust-line b{color:var(--ink-900);font-weight:700}
.stars{display:inline-flex;gap:2px;vertical-align:middle}
.stars svg{width:17px;height:17px;fill:var(--gold)}

.gift{display:inline-flex;align-items:flex-start;gap:12px;margin:var(--sp-6) auto 0;max-width:680px;
  background:var(--bg-surface);border:1px solid var(--ink-200);border-radius:var(--r-lg);padding:18px 22px;text-align:left;box-shadow:var(--sh-1)}
.gift .gi{width:38px;height:38px;border-radius:10px;background:var(--red-50);color:var(--red-600);display:grid;place-items:center;flex-shrink:0}
.gift .gi svg{width:21px;height:21px;fill:currentColor}
.gift p{font-size:16px;color:var(--ink-600);line-height:1.5}
.gift b{color:var(--ink-900);font-weight:700}

/* ===== Featured in ===== */
.featured-in{max-width:1100px;margin:0 auto;padding:var(--sp-5) 48px var(--sp-9);text-align:center}
.featured-in .lbl{font-size:14px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-400);margin-bottom:var(--sp-5)}
.press{display:flex;align-items:center;justify-content:center;gap:var(--sp-8);flex-wrap:wrap}
.press .pl{font-family:var(--font-serif);font-weight:500;font-size:27px;color:var(--ink-400);letter-spacing:.01em}

@media(max-width:860px){
  .hero{padding:var(--sp-8) 24px var(--sp-5)}
  .hero h1{font-size:42px}
  .hero .sub{font-size:18px}
  .nl-form{flex-direction:column}
  .featured-in{padding:var(--sp-5) 24px var(--sp-8)}
  .press{gap:var(--sp-5)}.press .pl{font-size:21px}
}
@media(max-width:520px){
  .hero h1{font-size:34px}
}
</style>
