---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCategories } from '../../lib/wordpress';

const categories = await getCategories();
---

<BaseLayout title="Categories" activePage="category">
  <section class="categories-page">
    <nav class="crumb"><a href="/">Home</a><span class="sep">/</span><span class="cur">Categories</span></nav>
    <div class="page-head">
      <h1>Topics & Categories</h1>
      <p class="subtitle">Explore in-depth playbooks, strategies, and lessons by topic to grow your YouTube channel.</p>
    </div>
    
    <div class="cat-grid">
      {categories.map((cat: any) => (
        <a href={`/${cat.slug}/`} class="cat-card">
          <div class="cat-body">
            <h3>{cat.name}</h3>
            <p class="cat-desc">{cat.description || "Explore our latest strategies and playbooks in this category."}</p>
            <span class="badge badge-count">{cat.count} {cat.count === 1 ? 'article' : 'articles'}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
.categories-page {
  max-width: 1400px;
  margin: 0 auto;
  padding: var(--sp-7) 48px var(--sp-8);
}
.crumb {
  font-size: 15px;
  color: var(--ink-500);
  margin-bottom: var(--sp-5);
}
.crumb a:hover {
  color: var(--red-600);
}
.crumb .sep {
  margin: 0 8px;
  color: var(--ink-300);
}
.crumb .cur {
  color: var(--ink-900);
  font-weight: 600;
}
.page-head {
  max-width: 720px;
  margin-bottom: var(--sp-7);
}
.page-head h1 {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 48px;
  line-height: 1.1;
  letter-spacing: -.03em;
  text-transform: capitalize;
}
.page-head .subtitle {
  font-size: 20px;
  color: var(--ink-600);
  margin-top: var(--sp-3);
  line-height: 1.6;
}

/* Grid layout */
.cat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-5);
}
.cat-card {
  background: var(--bg-surface);
  border: 1px solid var(--ink-200);
  border-radius: var(--r-lg);
  overflow: hidden;
  box-shadow: var(--sh-1);
  transition: all var(--dur) var(--ease);
  cursor: pointer;
  display: flex;
  flex-direction: column;
}
.cat-card:hover {
  box-shadow: var(--sh-3);
  transform: translateY(-3px);
  border-color: var(--red-200);
}
.cat-body {
  padding: var(--sp-5);
  display: flex;
  flex-direction: column;
  height: 100%;
}
.cat-body h3 {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 24px;
  line-height: 1.2;
  letter-spacing: -.01em;
  margin-bottom: 12px;
  color: var(--ink-900);
  transition: color .12s;
}
.cat-card:hover h3 {
  color: var(--red-600);
}
.cat-desc {
  font-size: 16px;
  color: var(--ink-600);
  line-height: 1.5;
  margin-bottom: var(--sp-4);
  flex-grow: 1;
}
.badge-count {
  align-self: flex-start;
  background: var(--bg-page);
  color: var(--ink-700);
  font-size: 13px;
  font-weight: 700;
  border: 1px solid var(--ink-200);
  padding: 6px 12px;
  border-radius: var(--r-pill);
}

@media(max-width:980px) {
  .categories-page {
    padding: var(--sp-6) 24px var(--sp-7);
  }
  .page-head h1 {
    font-size: 38px;
  }
  .cat-grid {
    grid-template-columns: 1fr 1fr;
  }
}
@media(max-width:620px) {
  .page-head h1 {
    font-size: 32px;
  }
  .cat-grid {
    grid-template-columns: 1fr;
  }
}
</style>
