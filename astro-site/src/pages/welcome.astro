---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="You're In! Welcome">
<main class="wrap">

  <!-- HERO -->
  <section class="hero-w">
    <span class="check"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span>
    <span class="badge badge-success" style="margin-bottom:var(--sp-5)"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg>You're subscribed</span>
    <h1>You're In! Welcome To The AI YouTube Operator</h1>
    <p class="intro">Hey — <b>Don Ninh</b> here. Thanks for joining!</p>
    <p class="count">You just joined <b>15,247+</b> creators building million-dollar YouTube businesses with AI.</p>
  </section>

  <!-- WHO AM I -->
  <section class="sec">
    <h2>Who Am I?</h2>
    <p>I went from <b>$5 to $1 million</b> in YouTube revenue — starting with nothing but a cheap laptop and a refusal to quit.</p>
    <p>Now I help people like you build AI-powered YouTube channels that generate real income while you sleep.</p>
  </section>

  <!-- REAL RESULTS -->
  <section class="sec">
    <h2>Real Results</h2>
    <ul class="clist">
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>Students hitting <b>20M views in 23 days</b></span></li>
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>Channels earning <b>$10K–$50K/month</b></span></li>
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>Complete beginners building <b>financial freedom</b></span></li>
    </ul>
  </section>

  <!-- WHAT YOU'LL GET -->
  <section class="sec">
    <h2>What You'll Get Every Tuesday</h2>
    <ul class="clist">
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>AI strategies, systems &amp; tools I'm actively using</span></li>
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>Real case studies with actual revenue numbers</span></li>
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>Templates you can steal</span></li>
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>Best links of the week — news, tools, products &amp; useful videos</span></li>
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>No BS — just what works</span></li>
    </ul>
  </section>

  <!-- CHECK YOUR INBOX -->
  <section class="inbox">
    <span class="kick"><svg viewBox="0 0 24 24" fill="currentColor" style="width:14px;height:14px"><path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4-8 5-8-5V6l8 5 8-5z"/></svg>Action needed</span>
    <h2>Check Your Inbox Now</h2>
    <p class="gift-txt">Your first email is waiting with: 🎁 <b>"The AI YouTube Toolkit"</b> — 18 AI tools + workflows + <b>$48K in discounts</b>.</p>
    <div class="cant">
      <div class="ct">Can't find it?</div>
      <ul>
        <li>Check your Spam / Promotions folder</li>
        <li>Move it to your Primary inbox</li>
        <li>Whitelist my email address</li>
      </ul>
    </div>
  </section>

  <!-- COMMUNITY -->
  <section class="community">
    <span class="ckick">🎁 Bonus</span>
    <h2>Join The Tube Operator Community — Free</h2>
    <p class="lead">As a newsletter subscriber, you get free access to our private community of YouTube creators and operators.</p>
    <div class="sub">Inside you'll find:</div>
    <ul class="clist">
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>Live Q&amp;A sessions with Don Ninh</span></li>
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>Channel critiques and feedback</span></li>
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>Members sharing real revenue numbers</span></li>
      <li><span class="ck"><svg viewBox="0 0 24 24"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg></span><span>Tools, templates &amp; resources updated weekly</span></li>
    </ul>
    <div class="cbtn-row"><a class="btn btn-primary" href="#">Join The Community Now <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></a></div>
    <p class="proof">Join the other operators already inside — <b>no sign-up needed</b>. We've already created your account; just check your inbox and click the link to jump in.</p>
  </section>

  <!-- SIGNOFF -->
  <section class="signoff">
    <div class="name">Don Ninh</div>
    <div class="role">Founder, TubeOperator</div>
    <p class="ps">P.S. I started with nothing. If I can build this, you can too. Let's do it together. 💪</p>
  </section>

  <div class="cta-row">
    <a class="btn btn-primary" href="/my-story/">Read My Story <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
  </div>

</main>
</BaseLayout>

<style>
/* welcome */
.wrap{max-width:760px;margin:0 auto;padding:var(--sp-8) 24px var(--sp-7)}
.hero-w{text-align:center;margin-bottom:var(--sp-8)}
.check{width:84px;height:84px;border-radius:50%;background:#E6F6EE;display:grid;place-items:center;margin:0 auto var(--sp-5)}
.check svg{width:46px;height:46px;fill:#1DA45A}
.badge-success{background:#E6F6EE;color:#0E5A30}
.hero-w h1{font-family:var(--font-display);font-weight:800;font-size:46px;line-height:1.12;letter-spacing:-.03em;text-transform:capitalize}
.hero-w .intro{font-size:20px;color:var(--ink-700);margin-top:var(--sp-5)}
.hero-w .intro b{color:var(--ink-900)}
.hero-w .count{font-size:17px;letter-spacing:-.01em;color:var(--ink-700);margin-top:var(--sp-3)}
.hero-w .count b{color:var(--red-600);font-weight:800}

.sec{margin-bottom:var(--sp-7)}
.sec h2{font-family:var(--font-display);font-weight:800;font-size:28px;letter-spacing:-.02em;margin-bottom:var(--sp-4);text-transform:capitalize}
.sec p{font-size:18px;color:var(--ink-700);margin-bottom:var(--sp-4)}
.sec p:last-child{margin-bottom:0}
.sec p b{color:var(--ink-900)}

.clist{list-style:none;display:flex;flex-direction:column;gap:14px}
.clist li{display:flex;gap:14px;align-items:flex-start;font-size:18px;color:var(--ink-700)}
.clist li .ck{width:26px;height:26px;border-radius:50%;background:var(--red-50);color:var(--red-600);display:grid;place-items:center;flex-shrink:0;margin-top:2px}
.clist li .ck svg{width:15px;height:15px;fill:currentColor}
.clist li b{color:var(--ink-900)}

/* inbox box */
.inbox{background:var(--bg-dark);border-radius:var(--r-xl);padding:var(--sp-7);color:#fff;text-align:center;margin:var(--sp-8) 0}
.inbox .kick{display:inline-flex;align-items:center;gap:8px;background:var(--red-500);color:#fff;font-size:13px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:7px 16px;border-radius:var(--r-pill);margin-bottom:var(--sp-4)}
.inbox h2{font-family:var(--font-display);font-weight:800;font-size:30px;letter-spacing:-.02em;color:#fff;text-transform:capitalize}
.inbox .gift-txt{font-size:18px;color:rgba(255,255,255,.82);margin:var(--sp-4) auto 0;max-width:48ch;line-height:1.6}
.inbox .gift-txt b{color:#fff}
.cant{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:var(--r-lg);padding:var(--sp-5);margin-top:var(--sp-5);text-align:left;max-width:420px;margin-left:auto;margin-right:auto}
.cant .ct{font-size:14px;font-weight:700;color:#fff;margin-bottom:12px}
.cant ul{list-style:none;display:flex;flex-direction:column;gap:9px}
.cant li{display:flex;gap:10px;align-items:center;font-size:15px;color:rgba(255,255,255,.72)}
.cant li::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--red-400);flex-shrink:0}

/* community */
.community{background:var(--bg-cream);border:1px solid var(--ink-200);border-radius:var(--r-xl);padding:var(--sp-7);margin:var(--sp-8) 0;box-shadow:var(--sh-1)}
.community .ckick{display:inline-flex;align-items:center;gap:7px;font-size:13px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--red-600);background:var(--red-50);padding:7px 14px;border-radius:var(--r-pill);margin-bottom:var(--sp-4)}
.community h2{font-family:var(--font-display);font-weight:800;font-size:28px;letter-spacing:-.02em;line-height:1.22;margin-bottom:var(--sp-3)}
.community .lead{font-size:18px;color:var(--ink-700);margin-bottom:var(--sp-5)}
.community .sub{font-size:16px;font-weight:700;color:var(--ink-900);margin-bottom:var(--sp-4)}
.community .cbtn-row{margin-top:var(--sp-6)}
.community .proof{font-size:15px;color:var(--ink-500);margin-top:var(--sp-4)}
.community .proof b{color:var(--ink-800);font-weight:700}

/* signoff */
.signoff{border-top:1px solid var(--ink-200);padding-top:var(--sp-6);margin-top:var(--sp-7)}
.signoff .name{font-family:var(--font-display);font-weight:800;font-size:20px}
.signoff .role{font-size:15px;color:var(--red-600);font-weight:600;margin-top:2px}
.signoff .ps{font-size:17px;color:var(--ink-600);font-style:italic;margin-top:var(--sp-5);line-height:1.7}
.cta-row{text-align:center;margin-top:var(--sp-7)}

@media(max-width:760px){
  .hero-w h1{font-size:34px}.inbox{padding:var(--sp-5)}.inbox h2{font-size:24px}
}
</style>
