---
/**
 * Subscribe Gate — client-side soft gate
 * All content is in the HTML but locked part is hidden via JS.
 * Cookie to_sub=1 → no gate, full content visible.
 */
interface Props {
  slug: string;
}
const { slug } = Astro.props;
const gateEmbedLayout = "{'id':'INLINE'}";
---

<div class="gate" id="gate">
  <div class="gate-fade"></div>
  <div class="gate-box">
    <div class="gate-title">Subscribe To Keep Reading</div>
    <p class="g-sub">This content is free, but you must be subscribed to keep reading.</p>

    <!-- GHL iframe embed (disabled — native gate-form active below)
    <div class="gate-embed">
      <iframe
        src="https://api.automator.vn/widget/form/nPFu6gucPwKBrLE9gYBN"
        style="height:400px;border:none;border-radius:0px"
        id="inline-nPFu6gucPwKBrLE9gYBN"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Blog Post Gate! "
        data-height="400"
        data-layout-iframe-id="inline-nPFu6gucPwKBrLE9gYBN"
        data-form-id="nPFu6gucPwKBrLE9gYBN"
        title="Blog Post Gate! "
        scrolling="no"
      ></iframe>
    </div>
    <script src="https://api.automator.vn/js/form_embed.js"></script>
    -->

    <form class="gate-form" id="gate-form">
      <input type="email" placeholder="Email" aria-label="Email address" required id="gate-email">
      <button class="btn btn-primary" type="submit" id="gate-btn">Subscribe</button>
    </form>
    <div class="gate-error" id="gate-error"></div>

    <button class="g-not" id="g-not" type="button">Not now</button>
  </div>
</div>

<script define:vars={{ slug }}>
  // Cookie helpers
  function getCookie(name) {
    const m = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
    return m ? m[1] : null;
  }

  // Already subscribed or dismissed → remove gate, show content
  const isSub = getCookie('to_sub') === '1';
  const isDismissed = getCookie('to_gate_dismiss') === '1';

  if (isSub || isDismissed) {
    const gate = document.getElementById('gate');
    if (gate) gate.style.display = 'none';
    
    // Note: locked and toc might not be in DOM yet during parser execution of this script,
    // but the script at the bottom of [slug].astro will handle showing them on load.
  }

  // Subscribe form
  const form = document.getElementById('gate-form');
  const emailInput = document.getElementById('gate-email');
  const btn = document.getElementById('gate-btn');
  const errorEl = document.getElementById('gate-error');
  const notNow = document.getElementById('g-not');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput?.value?.trim();
    if (!email) return;

    if (btn) { btn.disabled = true; btn.textContent = 'Subscribing…'; }
    if (errorEl) errorEl.textContent = '';

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          source: 'blog-gate',
          language: navigator.language,
        }),
      });
      if (!res.ok) throw new Error();

      // Set subscriber cookie (1 year) — prevents gate on future visits
      document.cookie = 'to_sub=1; path=/; max-age=31536000; SameSite=Lax; Secure';

      const gate = document.getElementById('gate');
      const locked = document.getElementById('locked-content');
      const toc = document.getElementById('toc');
      const sideNl = document.getElementById('side-nl');

      if (locked) locked.style.display = 'block';
      if (toc) toc.style.display = 'block';
      if (gate) gate.style.display = 'none';
      if (sideNl) sideNl.style.display = 'none';
    } catch {
      if (errorEl) errorEl.textContent = 'Something went wrong. Please try again.';
      if (btn) { btn.disabled = false; btn.textContent = 'Subscribe'; }
    }
  });

  notNow?.addEventListener('click', () => {
    document.cookie = 'to_gate_dismiss=1; path=/; max-age=604800; SameSite=Lax; Secure';
    
    // Query elements dynamically to ensure they are found after full DOM load
    const gate = document.getElementById('gate');
    const locked = document.getElementById('locked-content');

    if (gate) gate.style.display = 'none';
    if (locked) locked.style.display = 'block';
  });
</script>

<style>
.gate{position:relative;margin-top:var(--sp-6)}
.gate-fade{position:absolute;left:0;right:0;top:-200px;height:200px;background:linear-gradient(180deg,rgba(251,244,238,0),var(--bg-page) 88%);pointer-events:none}
.gate-box{position:relative;text-align:center;max-width:560px;margin:0 auto;padding:var(--sp-3) var(--sp-4) var(--sp-7)}
.gate-title{font-family:var(--font-display);font-weight:800;font-size:30px;letter-spacing:-.02em;color:var(--ink-900)}
.gate-box .g-sub{font-size:17px;color:var(--ink-600);margin:10px auto 0;max-width:44ch}
.gate-form{display:flex;gap:10px;max-width:440px;margin:var(--sp-5) auto 0}
.gate-form input{flex:1;font-family:var(--font-body);font-size:16px;line-height:1;padding:16px;border:1.5px solid var(--ink-200);border-radius:var(--r-sm);background:#fff;color:var(--ink-900)}
.gate-form input:focus{outline:none;border-color:var(--red-500);box-shadow:0 0 0 3px var(--red-100)}
.gate-error{font-size:14px;color:var(--red-600);margin-top:10px;min-height:20px}
.gate-embed{height:160px;overflow:hidden;margin:var(--sp-5) auto 0}
.gate-embed iframe{width:calc(100% + 17px)}
.g-not{display:block;margin:12px auto 0;background:none;border:none;color:var(--ink-400);text-decoration:underline;cursor:pointer;font-size:14px;font-family:var(--font-body)}
.g-not:hover{color:var(--ink-700)}
</style>
