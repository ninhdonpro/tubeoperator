---
interface Props {
  title: string;
  description?: string;
  activePage?: string;
}

const { title, description = 'Build AI-powered YouTube channels that generate real income. Strategies, tools, and systems from 20+ channels with 6B+ views.', activePage = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content={description} />
<title>{title} — TubeOperator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Lora:ital,wght@0,500;0,600;0,700;1,500&display=swap" rel="stylesheet">
</head>
<body>

<!-- ===== HEADER ===== -->
<header class="header">
  <div class="header-in">
    <a class="brand" href="/">
      <span class="brand-mark"><svg viewBox="0 0 24 24"><path d="M9.3 7.4c0-1.27 1.4-2.05 2.47-1.36l7.07 4.6a1.62 1.62 0 0 1 0 2.72l-7.07 4.6C10.7 18.65 9.3 17.87 9.3 16.6V7.4z"/></svg></span>
      <span class="brand-name">Tube<b>Operator</b></span>
    </a>
    <nav class="nav">
      <a href="/story" class:list={[{ active: activePage === 'story' }]}>My story</a>
      <a href="/blog" class:list={[{ active: activePage === 'blog' }]}>Blog</a>
      <a href="https://member.tubeoperator.com/shop/" target="_blank">Products</a>
      <a href="/contact" class:list={[{ active: activePage === 'contact' }]}>Contact</a>
    </nav>
    <div class="header-cta">
      <span class="acct"><svg viewBox="0 0 24 24"><path d="M12 12a5 5 0 100-10 5 5 0 000 10zm0 2c-4.4 0-8 2.2-8 5v1h16v-1c0-2.8-3.6-5-8-5z"/></svg></span>
      <button class="btn btn-primary btn-sm">Learn YouTube &amp; AI</button>
      <button class="menu-btn" aria-label="Menu"><svg viewBox="0 0 24 24"><path d="M3 6h18v2H3zM3 11h18v2H3zM3 16h18v2H3z"/></svg></button>
    </div>
  </div>
</header>

<main>
  <slot />
</main>

<!-- ===== FOOTER ===== -->
<footer class="footer">
  <div class="footer-in">
    <div class="foot-grid">
      <div class="foot-brand">
        <a class="brand" href="/">
          <span class="brand-mark" style="width:34px;height:34px"><svg viewBox="0 0 24 24"><path d="M9.3 7.4c0-1.27 1.4-2.05 2.47-1.36l7.07 4.6a1.62 1.62 0 0 1 0 2.72l-7.07 4.6C10.7 18.65 9.3 17.87 9.3 16.6V7.4z"/></svg></span>
          <span class="brand-name" style="font-size:19px">Tube<b>Operator</b></span>
        </a>
        <p>In-depth, AI-driven playbooks for creators who want to grow a YouTube channel like a business.</p>
      </div>
      <div>
        <h4>Explore</h4>
        <a href="/story">My story</a><a href="/blog">Blog</a><a href="https://member.tubeoperator.com/shop/" target="_blank">Products</a><a href="/">Newsletter</a>
      </div>
      <div>
        <h4>Topics</h4>
        <a href="/blog">Algorithm</a><a href="/blog">Thumbnails</a><a href="/blog">Editing</a><a href="/blog">Monetization</a>
      </div>
      <div>
        <h4>Company</h4>
        <a href="/story">About</a><a href="/contact">Contact</a><a href="#">Privacy</a><a href="#">Terms</a>
      </div>
    </div>
  </div>
  <div class="foot-bottom">
    <span class="cp">© {new Date().getFullYear()} TubeOperator. All rights reserved.</span>
    <div class="socials">
      <a href="#" aria-label="X"><svg viewBox="0 0 24 24"><path d="M18.9 2H22l-7.3 8.3L23 22h-6.8l-5.3-7-6 7H2l7.8-8.9L1.5 2h7l4.8 6.4zm-1.2 18h1.9L7.4 4H5.4z"/></svg></a>
      <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24"><path d="M12 2c2.7 0 3 0 4.1.1 1.1 0 1.8.2 2.4.5.6.2 1.1.5 1.6 1s.8 1 1 1.6c.3.6.5 1.3.5 2.4.1 1.1.1 1.4.1 4.1s0 3-.1 4.1c0 1.1-.2 1.8-.5 2.4-.2.6-.5 1.1-1 1.6s-1 .8-1.6 1c-.6.3-1.3.5-2.4.5-1.1.1-1.4.1-4.1.1s-3 0-4.1-.1c-1.1 0-1.8-.2-2.4-.5-.6-.2-1.1-.5-1.6-1s-.8-1-1-1.6c-.3-.6-.5-1.3-.5-2.4C2 15 2 14.7 2 12s0-3 .1-4.1c0-1.1.2-1.8.5-2.4.2-.6.5-1.1 1-1.6s1-.8 1.6-1c.6-.3 1.3-.5 2.4-.5C9 2 9.3 2 12 2zm0 5a5 5 0 100 10 5 5 0 000-10zm0 8.2a3.2 3.2 0 110-6.4 3.2 3.2 0 010 6.4zm5.2-8.4a1.2 1.2 0 100 2.4 1.2 1.2 0 000-2.4z"/></svg></a>
      <a href="#" aria-label="YouTube"><svg viewBox="0 0 24 24"><path d="M21.6 7.2c-.2-1-1-1.7-2-2C17.8 4.8 12 4.8 12 4.8s-5.8 0-7.6.4c-1 .3-1.8 1-2 2C2 9 2 12 2 12s0 3 .4 4.8c.2 1 1 1.7 2 2 1.8.4 7.6.4 7.6.4s5.8 0 7.6-.4c1-.3 1.8-1 2-2C22 15 22 12 22 12s0-3-.4-4.8zM10 15.5v-7l6 3.5-6 3.5z"/></svg></a>
    </div>
  </div>
</footer>

</body>
</html>

<style is:global>
:root{
  --red-50:#FDECEB;--red-100:#FAD0CD;--red-200:#F4A39C;--red-300:#EE756B;--red-400:#E8483B;
  --red-500:#E62117;--red-600:#C81C13;--red-700:#A3150E;--red-800:#7D100A;--red-900:#4F0A06;
  --ink-900:#0F0F0F;--ink-800:#1B1B1B;--ink-700:#2C2C2C;--ink-600:#4A4A4A;--ink-500:#6B6B6B;
  --ink-400:#909090;--ink-300:#C4C4C4;--ink-200:#E4E0DB;--ink-100:#F0ECE6;--ink-50:#F8F5F1;
  --bg-page:#FBF4EE;--bg-surface:#FFFFFF;--bg-cream:#FAF3EC;--bg-dark:#1B1B1B;
  --gold:#F2B600;--success:#1DA45A;
  --font-display:'Plus Jakarta Sans',system-ui,sans-serif;
  --font-body:'Plus Jakarta Sans',system-ui,sans-serif;
  --font-serif:'Lora',Georgia,serif;
  --sp-1:4px;--sp-2:8px;--sp-3:12px;--sp-4:16px;--sp-5:24px;--sp-6:32px;--sp-7:48px;--sp-8:64px;--sp-9:96px;
  --r-sm:8px;--r-md:12px;--r-lg:18px;--r-xl:28px;--r-pill:999px;
  --sh-1:0 1px 2px rgba(15,15,15,.05);--sh-2:0 2px 8px rgba(15,15,15,.06);
  --sh-3:0 8px 24px rgba(15,15,15,.08);--sh-red:0 8px 22px rgba(230,33,23,.24);
  --ease:cubic-bezier(.4,0,.2,1);--dur:200ms;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font-body);background:var(--bg-page);color:var(--ink-900);font-size:18px;line-height:1.7;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}

/* ===== Buttons ===== */
.btn{font-family:var(--font-display);font-weight:700;font-size:17px;border:none;cursor:pointer;border-radius:var(--r-sm);
  padding:17px 36px;display:inline-flex;align-items:center;justify-content:center;gap:10px;transition:all var(--dur) var(--ease);line-height:1;white-space:nowrap;text-transform:capitalize}
.btn svg{width:18px;height:18px}
.btn-primary{background:var(--red-500);color:#fff;box-shadow:var(--sh-red)}
.btn-primary:hover{background:var(--red-600);transform:translateY(-1px)}
.btn-primary:active{background:var(--red-700);transform:translateY(0)}
.btn-outline{background:transparent;color:var(--ink-900);box-shadow:inset 0 0 0 1.5px var(--ink-300)}
.btn-outline:hover{box-shadow:inset 0 0 0 1.5px var(--red-500);color:var(--red-600)}
.btn-sm{padding:13px 26px;font-size:15px}
.btn-full{width:100%}

.badge{display:inline-flex;align-items:center;gap:6px;font-size:14px;font-weight:700;padding:9px 18px;border-radius:var(--r-pill)}
.badge-soft{background:var(--red-50);color:var(--red-700)}
.badge-dark{background:var(--ink-900);color:#fff}
.badge-red{background:var(--red-500);color:#fff}
.badge svg{width:14px;height:14px;fill:currentColor}

/* ===== Header ===== */
.header{position:sticky;top:0;z-index:40;background:rgba(251,244,238,.85);backdrop-filter:blur(10px);border-bottom:1px solid var(--ink-200)}
.header-in{max-width:1400px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:var(--sp-5);padding:18px 48px}
.brand{display:flex;align-items:center;gap:12px}
.brand-mark{width:40px;height:40px;background:var(--red-500);border-radius:11px;display:grid;place-items:center;flex-shrink:0;box-shadow:var(--sh-red)}
.brand-mark svg{width:23px;height:23px;fill:#fff}
.brand-name{font-family:var(--font-display);font-weight:800;font-size:21px;letter-spacing:-.02em}
.brand-name b{color:var(--red-500)}
.nav{display:flex;align-items:center;gap:40px}
.nav a{font-size:16px;font-weight:600;color:var(--ink-700);transition:color .12s var(--ease);text-transform:capitalize}
.nav a:hover,.nav a.active{color:var(--red-600)}
.header-cta{display:flex;align-items:center;gap:var(--sp-4)}
.acct{width:42px;height:42px;border-radius:50%;border:1.5px solid var(--ink-200);display:grid;place-items:center;color:var(--ink-500);background:var(--bg-surface)}
.acct svg{width:22px;height:22px;fill:currentColor}
.menu-btn{display:none;background:none;border:none;cursor:pointer;color:var(--ink-900)}
.menu-btn svg{width:30px;height:30px;fill:currentColor}

/* ===== Footer ===== */
.footer{background:var(--bg-cream);border-top:1px solid var(--ink-200)}
.footer-in{max-width:1400px;margin:0 auto;padding:var(--sp-8) 48px var(--sp-6)}
.foot-grid{display:grid;grid-template-columns:1.5fr repeat(3,1fr);gap:var(--sp-6)}
.foot-brand p{font-size:15px;color:var(--ink-500);max-width:34ch;margin-top:14px}
.footer h4{font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--ink-400);margin-bottom:var(--sp-3)}
.footer .foot-grid a{display:block;font-size:15px;color:var(--ink-600);padding:5px 0}
.footer .foot-grid a:hover{color:var(--red-600)}
.foot-bottom{max-width:1400px;margin:0 auto;padding:var(--sp-5) 48px;border-top:1px solid var(--ink-200);
  display:flex;align-items:center;justify-content:space-between;gap:var(--sp-4);flex-wrap:wrap}
.foot-bottom .cp{font-size:14px;color:var(--ink-400)}
.socials{display:flex;gap:14px}
.socials a{width:38px;height:38px;border-radius:50%;background:var(--bg-surface);border:1px solid var(--ink-200);
  display:grid;place-items:center;color:var(--ink-500);transition:all .12s var(--ease)}
.socials a:hover{color:var(--red-600);border-color:var(--red-300)}
.socials svg{width:18px;height:18px;fill:currentColor}

@media(max-width:860px){
  .nav{display:none}.acct{display:none}.menu-btn{display:block}
  .header-in{padding:14px 24px}
  .footer-in,.foot-bottom{padding-left:24px;padding-right:24px}
  .foot-grid{grid-template-columns:1fr 1fr}
}
@media(max-width:520px){
  .foot-grid{grid-template-columns:1fr}
  .foot-bottom{flex-direction:column;align-items:flex-start}
}
</style>
