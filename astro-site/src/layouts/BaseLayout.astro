---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Build AI-powered YouTube channels that generate real income. Strategies, tools, and systems from 20+ channels with 6B+ views.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} | Tube Operator</title>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">Tube Operator</a>
      <nav>
        <ul class="nav-links">
          <li><a href="/">Blog</a></li>
          <li><a href="/story">My Story</a></li>
          <li><a href="https://member.tubeoperator.com/shop/" target="_blank">Shop</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">Tube Operator</div>
      <p class="footer-text">
        &copy; {new Date().getFullYear()} Tube Operator by Don Ninh. All rights reserved.
      </p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
