# HighLevel (GHL) API credentials
# Copy this file to astro-site/.env and fill in the real values.
# For Cloudflare Pages production: set these in the Cloudflare dashboard → Settings → Environment variables.
GHL_PRIVATE_TOKEN=your_ghl_private_integration_token
GHL_LOCATION_ID=your_ghl_location_id
# Language custom field ID — fetch once from GET /locations/{id}/customFields, find name="Language"
GHL_LANGUAGE_FIELD_ID=your_language_custom_field_id
